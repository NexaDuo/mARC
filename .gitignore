# --- Secrets / local env (never commit) ---
.env
.env.*
!.env.example
*.local

# Per-repo binding is created in the CONSUMING repo, not here.
# Ignore any stray copy so real values never land in the plugin repo.
.claude/team.config
# Personal, per-machine Claude Code overrides (e.g. a local ANTHROPIC_BASE_URL
# proxy). Never commit — it would force everyone's settings. The shared
# .claude/settings.json (enabledPlugins) IS committed; only the *.local one is not.
.claude/settings.local.json

# --- OS / editor cruft ---
.DS_Store
Thumbs.db
*.swp
*~
.idea/
.vscode/

# --- Node (in case tooling is added later) ---
node_modules/
npm-debug.log*
yarn-error.log*

# --- Logs / temp ---
*.log
tmp/
.tmp/

# Local Serena tooling config (not part of the versioned plugin)
.serena/
