# mARC — per-repo team binding (TOML)
# ------------------------------------------------------------------------------
# Copy this file to the CONSUMING repo as `.claude/team.toml` and fill it in.
# It is NOT part of the mARC plugin; it lives in each repo the team works on.
#
# The mARC SessionStart hook prints this file into context at the start of every
# session, so `@techlead` and the specialists (`@dev`/`@sre`/`@design`/`@sec`/
# `@rev`/`@research`) learn the repo's concrete facts instead of guessing them.
# Anything omitted here falls back to runtime discovery (e.g. `gh repo view`,
# `gh project list`).
#
# Format: standard TOML. Inline comments after a value are fine.
#
# SHELL-EXTRACTION DISCIPLINE (hard rule): keep every KEY NAME UNIQUE across the
# WHOLE file, regardless of section. The plugin's shell snippets extract values
# with zero dependencies (no TOML CLI) via patterns like
#   sed -n 's/^ *gh_repo *= *"\{0,1\}\([^"#]*\)"\{0,1\}.*/\1/p'
# which match by key name alone and would silently pick the wrong value if two
# sections reused a name. Sections exist for humans; keys are the contract.
# ------------------------------------------------------------------------------

# --- GitHub binding (used by `@techlead` to record + track work) ---
[github]
# The org that owns the repo and the Project board.
gh_org = "YourOrg"
# Full "owner/name" slug of the repo where issues/PRs are filed.
gh_repo = "YourOrg/your-repo"
# The GitHub Project (v2) number that is the team's source-of-truth board.
# Set the EXACT board number. Do NOT use the owner's auto-created "untitled"
# project (often #1) — that routes issues to the wrong board. Omit only if you
# want `@techlead` to list candidates and ask/disambiguate by title at runtime.
project_number = 42
# Optional: the Project's title, to disambiguate when the org has several.
project_title = "your-repo"

# --- Board provider (optional) ---
[board]
# Which backend `scripts/board.py` normalizes against. Defaults to
# "github" when omitted. A future Azure DevOps / Jira provider plugs in here
# without changing the normalized digest contract downstream tooling reads.
provider = "github"

# --- Architecture authority ---
[architecture]
# Path (relative to repo root) to the file `@techlead`/specialists must respect.
agents_doc = "AGENTS.md"

# --- Team artifacts workspace (optional) ---
[workspace]
# Folder (relative to repo root) where the OPERATOR materializes durable
# specialist artifacts (research briefs, security reports, decision records)
# from issue comments, landing them via reviewed PRs only. Read-only agents
# (`@sec`/`@research`) never write it. The value MUST be a relative, in-repo
# path — reject absolute paths and any `..` component; a violating value is
# treated as unset and flagged to the user. Before choosing a path, check
# whether it is publicly served (e.g. docs/ on GitHub Pages publishes on push)
# — never put sensitive content in a published folder. Omit to keep artifacts
# in issue comments only.
workspace_dir = "docs/marc"

# --- Correctness review gate (optional) ---
[review]
# Paths whose diff escalates @rev's `/code-review` pass beyond the default
# `medium` effort. A subagent can't spawn subagents, so @rev itself stays
# capped at `medium` (`high` silently degrades to inline-only from inside a
# subagent) — a diff touching a declared hot surface instead escalates to the
# OPERATOR running `/code-review` at `high` directly, or @rev being dispatched
# with an explicit high-effort override. Native TOML array; empty by default.
hot_surfaces = []

# --- Key source paths (where the specialists do their work) ---
[paths]
# Native TOML arrays; adjust to the repo's real layout. Purely informational
# hints that sharpen a dispatch spec — the specialists still read the tree
# themselves.
app_paths = ["src/", "services/"]
iac_paths = ["infrastructure/", "deploy/"]
test_paths = ["tests/", "e2e/"]
ui_paths = ["web/", "frontend/"]

# --- Validation ---
[validation]
# The single command that proves the change works (run locally + in CI).
validation_command = "npm run test:all"
# The health-check / smoke entrypoint `@sre` runs on a cadence, if any.
health_check_command = "./scripts/health-check.sh"

# --- Release-phase facts (what "done" requires in THIS repo) ---
[release]
# Does a real staging->prod pipeline exist? (true/false)
# If false, the mandatory release phases are N/A and should be stated explicitly.
has_release_pipeline = true
# Public URLs the specialists validate against with real requests.
real_urls = ["https://staging.example.com", "https://app.example.com"]
# Free-text notes on the deploy model / non-negotiables specific to this repo.
release_notes = "deploy via GitHub Actions; validate with real URLs; monitor CI to green."
